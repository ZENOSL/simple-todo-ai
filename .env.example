# =============================================================================
# Simple Todo AI — Environment Variables Reference
# Copy to .env and fill in all values before running.
# NEVER commit .env to version control.
# In Railway: set these via Dashboard -> Service -> Variables.
# =============================================================================

# --- Runtime ---
NODE_ENV=production
# Backend listen address (Railway injects PORT automatically)
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# --- Database (Railway PostgreSQL plugin auto-sets DATABASE_URL) ---
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Cache (Railway Redis plugin auto-sets REDIS_URL) ---
REDIS_URL=redis://host:6379

# --- Auth ---
# Generate with: openssl rand -hex 64
JWT_SECRET=replace-with-64-byte-random-hex-string
JWT_REFRESH_SECRET=replace-with-different-64-byte-random-hex-string

# Cookie signing (falls back to JWT_SECRET if unset)
# Generate with: openssl rand -hex 32
COOKIE_SECRET=replace-with-32-byte-random-hex-string

# --- AI Service (Zhipu AI / GLM) ---
GLM_API_KEY=your-glm-api-key
GLM_API_BASE=https://open.bigmodel.cn/api/paas/v4
GLM_PRIMARY_MODEL=glm-4-flash
GLM_FALLBACK_MODEL=glm-4-air

# --- CORS ---
# Comma-separated list of allowed origins.
# Set to your Railway frontend URL in production, e.g.:
# CORS_ORIGIN=https://simple-todo-ai-frontend.up.railway.app
CORS_ORIGIN=http://localhost:3000

# --- Frontend (Next.js public vars — must be prefixed NEXT_PUBLIC_) ---
# Set to the Railway backend service public URL in production.
NEXT_PUBLIC_API_URL=https://your-backend.up.railway.app

# --- Stripe (optional at MVP — required for subscription features) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
