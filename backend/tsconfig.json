{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "exactOptionalPropertyTypes": false
  },
  "include": [
    "src/server.ts",
    "src/routes/**/*",
    "src/middleware/**/*",
    "src/services/**/*",
    "src/lib/prisma.ts",
    "src/lib/redis.ts",
    "src/types/**/*",
    "src/ai/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
