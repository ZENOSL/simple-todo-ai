# Environment — NEVER commit real secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# .env.example IS committed — it is the reference template

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# TypeScript build info
tsconfig.tsbuildinfo
*.tsbuildinfo

# Testing
coverage/

