# ============================================================
# Stage 1 — builder
# Install all dependencies and build Next.js
# Build context: repository root (Railway default)
# Only frontend/ files are copied — no backend contamination
# ============================================================
FROM node:20-alpine AS builder
WORKDIR /app

# Copy frontend package files first for layer cache efficiency
COPY frontend/package*.json ./
RUN npm ci

# Copy frontend source (next.config.ts, src/, public/, tsconfig.json, etc.)
COPY frontend/ .

# NEXT_PUBLIC_API_URL must be baked in at build time —
# Next.js writes rewrites into routes-manifest.json during next build.
ARG NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}

# Build Next.js — outputs to .next/standalone (requires output:'standalone'
# in next.config.ts) plus .next/static for static assets
RUN npm run build

# ============================================================
# Stage 2 — runner
# Minimal production image using the standalone output
# ============================================================
FROM node:20-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# The standalone build bundles its own minimal node_modules;
# we only need to copy the three output directories.
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
COPY --from=builder /app/public ./public

EXPOSE 3000

# server.js is the entrypoint generated by Next.js standalone mode
CMD ["node", "server.js"]
